# ══════════════════════════════════════════════════════════════
#  XiaoYueDict — Cloud VPS Environment Configuration
#  Copy this to .env on the VPS and fill in real values.
# ══════════════════════════════════════════════════════════════

# ── Database Configuration ──
POSTGRES_DB=xiaoyue
POSTGRES_USER=xiaoyue
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgres://xiaoyue:CHANGE_ME_strong_password_here@db:5432/xiaoyue

# ── Django Environment ──
DJANGO_DEBUG=False
ALLOWED_HOSTS=api.cnendict.xyz
SECRET_KEY=CHANGE_ME_random_64_char_string
JWT_SECRET_KEY=CHANGE_ME_random_64_char_string

# ── Redis & Celery Config ──
REDIS_PASSWORD=CHANGE_ME_strong_password_here
REDIS_URL=redis://:CHANGE_ME_strong_password_here@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_strong_password_here@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_strong_password_here@redis:6379/0
REDIS_CACHE_URL=redis://:CHANGE_ME_strong_password_here@redis:6379/1

# ── AI Services Endpoints (via Private IP Tunnel) ──
# Local machine IP: 100.127.227.6 (Tailscale/ZeroTier)
# VPS IP: 100.92.141.97
AI_SERVICE_EN_URL=http://100.127.227.6:8000/api/v1/score
AI_SERVICE_ZH_URL=http://100.127.227.6:8001/api/v1/score

# ── GCP Configuration ──
# key.json is mounted via docker-compose volume from /opt/xiaoyue/secure/key.json
GOOGLE_APPLICATION_CREDENTIALS=/app/key.json
GS_BUCKET_NAME=cnen-bucket
XIAOYUE_DATA_ROOT=/data

# ── CORS & Security ──
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://cnendict.xyz,https://www.cnendict.xyz
CSRF_TRUSTED_ORIGINS=https://api.cnendict.xyz,https://cnendict.xyz,https://www.cnendict.xyz

# ── Frontend URL (used in email templates, notifications, etc.) ──
FRONTEND_URL=https://cnendict.xyz
