# ══════════════════════════════════════════════════════════════
# XiaoYueDict .gitignore
# ══════════════════════════════════════════════════════════════

# ── Environment Variables & Secrets ──
.env
.env.*
!.env.example
!.env.cloud.example
!.env.production.example
*.pem
*.key
xiaoyue-api-key.json
secret*.json

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
venv/
.venv/
env/
*.egg

# ── AI Model Weights & Caches (LARGE FILES — never commit) ──
# English service (Faster-Whisper)
ai_service_en/models_cache/
ai_service_en/models_weights/
ai_service_en_v2/
# Chinese service (FunASR)
ai_service_zh/models_cache/
ai_service_zh/models_weights/

# Model file extensions (safety net)
*.pth
*.pt
*.bin
*.safetensors
*.onnx
*.ckpt
*.h5
*.tflite

# HuggingFace / ModelScope caches
.cache/

# ── Model Training (local experiments — not for prod) ──
model_training/

# ── Django ──
db.sqlite3
db.sqlite3-journal
core_django/media/
core_django/audio_temp/
core_django/staticfiles/
/media/
/audio_temp/

# ── Node / Next.js ──
node_modules/
.next/
out/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.turbo/

# ── IDE / OS Files ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# ── Logs ──
*.log

# ── Docker ──
*.tar
docker-compose.override.yml

# ── Agents / AI generated data ──
.agents/

# ── Misc ──
*.bak
*.tmp
*.temp
coverage/
.nyc_output/
/ai_service_zh/scripts
/ai_service_en/scripts
/ai_service_en/model/whisper_cache
/frontend_nextjs
.cursorrules
.clauderules
  
# ── Temporary Test Scripts & Outputs ──  
test*.py  
output*.txt  
core_django/test*.py  
core_django/hsk_data/ 
/test_s
core_django/key.json
core_django/cnen-auth-key.json

# ── TTS Service ──
tts_service/cache/
**/key.json
/core_django/data
/scripts
